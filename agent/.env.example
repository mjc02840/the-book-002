# .env.example
# Agent Configuration

AGENT_NAME=t630-default
LOG_PATH=/var/log/auth.log
UPLOAD_INTERVAL=3600

# FTP Configuration (for OVH deployment)
FTP_HOST=your-ovh-domain.ovh.net
FTP_USER=ftp_username
FTP_PASS=ftp_password
FTP_REMOTE_DIR=/logs

# Local Development (set to 'local' to skip FTP, write to ./uploads/)
MODE=local
UPLOAD_DIR=./uploads
